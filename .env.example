# Vercel KV (自动注入)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# QQ 邮箱
QQ_EMAIL=your-email@qq.com
QQ_EMAIL_AUTH_CODE=your-auth-code

# ====== AI 模型配置 ======
# 提供商选择: ollama-gemma4 | ollama-qwen3 | deepseek | gemini | qwen | zhipu
LLM_PROVIDER=ollama-gemma4

# --- 方式一：使用内置提供商（推荐）---
# 只需设置 LLM_PROVIDER + 对应的 API Key

# Ollama (本地，无需 API Key)
# LLM_PROVIDER=ollama-gemma4
# 需要先安装: https://ollama.com/download
# 拉取模型: ollama pull gemma4:e4b

# DeepSeek API
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-api-key

# Google Gemini API
# LLM_PROVIDER=gemini
# LLM_API_KEY=your-gemini-api-key

# 通义千问 API (阿里云)
# LLM_PROVIDER=qwen
# LLM_API_KEY=your-dashscope-api-key

# 智谱 GLM API
# LLM_PROVIDER=zhipu
# LLM_API_KEY=your-zhipu-api-key

# --- 方式二：自定义配置（高级）---
# 设置以下环境变量将覆盖内置提供商配置
# LLM_TYPE=openai-compatible  (ollama | openai-compatible | gemini)
# LLM_API_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=your-api-key
# LLM_MODEL=gemma4:e4b
# LLM_BATCH_SIZE=15
# LLM_SUPPORTS_JSON=false

# 安全
CRON_SECRET=your-cron-secret

# GitHub (可选，提升 API 限额)
GITHUB_TOKEN=
